    {
      "parameters": {
        "jsCode": "let code =\n  $json.output?.[0]?.content?.[0]?.text ||\n  $json.content?.[0]?.text ||\n  $json.choices?.[0]?.message?.content ||\n  $json.code ||\n  \"\";\n\ncode = code\n  .replace(/```tsx/g, \"\")\n  .replace(/```jsx/g, \"\")\n  .replace(/```javascript/g, \"\")\n  .replace(/```js/g, \"\")\n  .replace(/```/g, \"\")\n  .trim();\n\nreturn [\n  {\n    json: {\n      sessionId: $('Webhook').item.json.body.sessionId,\n      filePath: 'src/pages/Landing.tsx',\n      code: code\n    }\n  }\n];"
      },
