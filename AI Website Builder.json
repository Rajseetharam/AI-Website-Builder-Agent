      "parameters": {
        "jsCode": "const history = items.map(item => ({\n  role: item.json.role,\n  content: item.json.message\n}));\n\nreturn [\n  {\n    json: {\n      sessionId: $('Webhook').first().json.body.sessionId,\n\n      userMessage: $('Webhook').first().json.body.message,\n\n      existingCode: $('Load Conversation Memory').first().json.file_content || \"\",\n\n      history\n    }\n  }\n];"
      },
